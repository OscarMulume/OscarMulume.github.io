    .hero h1{font-size:clamp(2.5rem,6.5vw,5rem);font-weight:900;line-height:1.05;letter-spacing:-.03em;margin-bottom:.5rem}
    .hero h1 .accent{background:linear-gradient(135deg,var(--blue-br),var(--indigo));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
