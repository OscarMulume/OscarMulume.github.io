    :root{--bg:#0a0a0f;--bg2:#111118;--card:rgba(255,255,255,0.03);--border:rgba(255,255,255,0.08);--border-h:rgba(255,255,255,0.15);--text:#f0f0f5;--text2:#8888aa;--blue:#3b82f6;--blue-g:rgba(59,130,246,0.15);--blue-br:#60a5fa;--green:#22c55e;--indigo:#818cf8;--orange:#f97316;--red:#ef4444}
    html{scroll-behavior:smooth}
    body{font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    a{color:inherit;text-decoration:none}
    ul{list-style:none}
    .bg-grid{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px);background-size:64px 64px}
