  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0a0f;
      --bg2: #111118;
      --card: rgba(255,255,255,0.03);
      --border: rgba(255,255,255,0.08);
      --border-h: rgba(255,255,255,0.15);
      --text: #f0f0f5;
      --text2: #8888aa;
      --blue: #3b82f6;
      --blue-glow: rgba(59,130,246,0.15);
      --blue-bright: #60a5fa;
      --green: #22c55e;
      --indigo: #818cf8;
    }
    html { scroll-behavior: smooth; }
    body { font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif; background:var(--bg); color:var(--text); line-height:1.6; -webkit-font-smoothing:antialiased; overflow-x:hidden; }

    /* Background */
    .bg-grid { position:fixed; inset:0; z-index:0; background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px); background-size:64px 64px; pointer-events:none; }
    .glow { position:fixed; border-radius:50%; filter:blur(120px); pointer-events:none; z-index:0; }
    .glow-1 { width:600px; height:600px; top:-200px; right:-100px; background:rgba(59,130,246,0.06); }
    .glow-2 { width:400px; height:400px; bottom:10%; left:-100px; background:rgba(99,102,241,0.04); }

    /* Nav */
    .nav { position:fixed; top:0; left:0; right:0; z-index:100; padding:1rem 0; transition:all .3s; border-bottom:1px solid transparent; }
    .nav.scrolled { background:rgba(10,10,15,0.85); backdrop-filter:blur(20px); border-bottom:1px solid var(--border); }
    .nav-inner { max-width:1200px; margin:0 auto; padding:0 2rem; display:flex; justify-content:space-between; align-items:center; }
    .logo { font-size:1.25rem; font-weight:800; color:var(--text); text-decoration:none; letter-spacing:-.02em; }
    .logo span { color:var(--blue); }
    .nav-links { display:flex; gap:2.5rem; align-items:center; }
    .nav-links a { color:var(--text2); text-decoration:none; font-size:.875rem; font-weight:500; transition:color .2s; }
    .nav-links a:hover { color:var(--text); }
    .nav-cta { padding:.5rem 1.25rem; border:1px solid var(--blue); border-radius:8px; background:var(--blue-glow); color:var(--blue-bright); text-decoration:none; font-size:.875rem; font-weight:600; transition:all .2s; }
    .nav-cta:hover { background:rgba(59,130,246,0.25); border-color:var(--blue-bright); }
    .mob-btn { display:none; background:none; border:none; color:var(--text); cursor:pointer; padding:.5rem; }
    .mob-menu { display:none; position:absolute; top:100%; left:0; right:0; background:rgba(10,10,15,.95); backdrop-filter:blur(20px); border-bottom:1px solid var(--border); padding:1.5rem 2rem; flex-direction:column; gap:1.25rem; }
    .mob-menu.open { display:flex; }
    .mob-menu a { color:var(--text2); text-decoration:none; font-size:1rem; font-weight:500; }

    /* Hero */
    .hero { min-height:100vh; display:flex; align-items:center; padding:8rem 2rem 4rem; max-width:1200px; margin:0 auto; position:relative; z-index:1; }
    .hero-wrap { max-width:750px; }
    .badge { display:inline-flex; align-items:center; gap:.5rem; padding:.375rem 1rem; border-radius:100px; background:rgba(59,130,246,.08); border:1px solid rgba(59,130,246,.2); font-size:.75rem; font-weight:600; color:var(--blue-bright); letter-spacing:.08em; text-transform:uppercase; margin-bottom:2rem; }
    .badge-dot { width:6px; height:6px; border-radius:50%; background:var(--green); animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .hero h1 { font-size:clamp(2.75rem,7vw,5.5rem); font-weight:900; line-height:1.05; letter-spacing:-.03em; margin-bottom:.5rem; }
    .hero h1 .accent { background:linear-gradient(135deg,var(--blue-bright),var(--indigo)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .role { font-size:clamp(1.1rem,2vw,1.35rem); color:var(--blue-bright); font-weight:600; margin-bottom:1.25rem; }
    .hero-desc { font-size:1.0625rem; color:var(--text2); max-width:600px; margin-bottom:2.5rem; line-height:1.8; }
    .hero-btns { display:flex; gap:1rem; flex-wrap:wrap; }
    .btn-p { display:inline-flex; align-items:center; gap:.5rem; padding:.875rem 1.75rem; border-radius:10rem; font-size:.9375rem; font-weight:600; text-decoration:none; transition:all .25s; background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; border:1px solid rgba(255,255,255,.1); box-shadow:0 4px 24px rgba(59,130,246,.25),inset 0 1px 0 rgba(255,255,255,.1); }
    .btn-p:hover { transform:translateY(-2px); box-shadow:0 8px 40px rgba(59,130,246,.35); }
    .btn-s { display:inline-flex; align-items:center; gap:.5rem; padding:.875rem 1.75rem; border-radius:10rem; font-size:.9375rem; font-weight:600; text-decoration:none; transition:all .25s; background:var(--card); color:var(--text); border:1px solid var(--border); }
    .btn-s:hover { border-color:var(--border-h); transform:translateY(-2px); }

    /* Location tag */
    .loc { display:flex; align-items:center; gap:.5rem; margin-top:2.5rem; font-size:.875rem; color:var(--text2); }
    .loc svg { width:16px; height:16px; }

    /* Stats */
    .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; margin-top:3.5rem; padding-top:2rem; border-top:1px solid var(--border); }
    .stat-n { font-size:1.5rem; font-weight:800; letter-spacing:-.02em; }
    .stat-l { font-size:.75rem; color:var(--text2); margin-top:.125rem; text-transform:uppercase; letter-spacing:.06em; }

    /* Section */
    section { position:relative; z-index:1; }
    .sw { max-width:1200px; margin:0 auto; padding:6rem 2rem; }
    .sh { text-align:center; margin-bottom:4rem; }
    .sl { display:inline-block; font-size:.7rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; color:var(--blue-bright); margin-bottom:1rem; }
    .st { font-size:clamp(2rem,4vw,3rem); font-weight:800; letter-spacing:-.03em; }
    .sd { font-size:1.0625rem; color:var(--text2); max-width:600px; margin:1rem auto 0; line-height:1.7; }

    /* Cards */
    .cg { display:grid; grid-template-columns:repeat(auto-fit,minmax(340px,1fr)); gap:1.5rem; }
    .card { position:relative; padding:2rem; border-radius:16px; background:var(--card); border:1px solid var(--border); transition:all .3s; overflow:hidden; }
    .card::before { content:''; position:absolute; inset:0; border-radius:16px; background:radial-gradient(400px circle at var(--mx,50%) var(--my,50%),rgba(59,130,246,.06),transparent 60%); opacity:0; transition:opacity .3s; pointer-events:none; }
    .card:hover::before { opacity:1; }
    .card:hover { border-color:rgba(59,130,246,.25); transform:translateY(-4px); }
    .ci { width:44px; height:44px; border-radius:12px; margin-bottom:1.25rem; background:rgba(59,130,246,.1); border:1px solid rgba(59,130,246,.15); display:flex; align-items:center; justify-content:center; }
    .ci svg { width:22px; height:22px; color:var(--blue-bright); }
    .card h3 { font-size:1.125rem; font-weight:700; margin-bottom:.5rem; }
    .card p { font-size:.9375rem; color:var(--text2); line-height:1.7; }

    /* Experience */
    .tl { max-width:800px; margin:0 auto; }
    .tli { position:relative; padding-left:2.5rem; padding-bottom:3rem; border-left:2px solid var(--border); }
    .tli:last-child { border-left:0; padding-bottom:0; }
    .tld { position:absolute; left:-7px; top:0; width:12px; height:12px; border-radius:50%; background:var(--blue); border:3px solid var(--bg); box-shadow:0 0 0 3px rgba(59,130,246,.15); }
    .tld.old { background:var(--text2); box-shadow:none; }
    .tlh { display:flex; flex-wrap:wrap; align-items:center; gap:.75rem; margin-bottom:.25rem; }
    .tlt { font-size:1.125rem; font-weight:700; }
    .tlb { padding:.25rem .75rem; border-radius:100px; font-size:.7rem; font-weight:600; }
    .tlb.now { background:rgba(34,197,94,.1); color:var(--green); border:1px solid rgba(34,197,94,.2); }
    .tlb.past { background:rgba(255,255,255,.04); color:var(--text2); }
    .tlc { font-size:.875rem; color:var(--blue-bright); font-weight:500; margin-bottom:.5rem; }
    .tldesc { font-size:.9375rem; color:var(--text2); line-height:1.8; }
    .tldesc li { margin-bottom:.35rem; padding-left:1rem; position:relative; list-style:none; }
    .tldesc li::before { content:'▸'; position:absolute; left:0; color:var(--blue); font-size:.8rem; }

    /* Skills */
    .skills-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.5rem; }
    .skill-cat { padding:2rem; border-radius:16px; background:var(--card); border:1px solid var(--border); }
    .skill-cat h3 { font-size:.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--blue-bright); margin-bottom:1.25rem; }
    .skill-tags { display:flex; flex-wrap:wrap; gap:.5rem; }
    .skill-tag { padding:.35rem .875rem; border-radius:8px; font-size:.8125rem; font-weight:500; background:rgba(255,255,255,.04); border:1px solid var(--border); color:var(--text2); }

    /* Certs */
    .cert-row { display:flex; flex-wrap:wrap; justify-content:center; gap:.75rem; }
    .cert { display:flex; align-items:center; gap:.5rem; padding:.625rem 1.25rem; border-radius:12px; background:var(--card); border:1px solid var(--border); font-size:.8125rem; font-weight:500; }
    .cert svg { width:16px; height:16px; }

    /* CV */
    .cv-max { max-width:640px; margin:0 auto; }
    .cv-card { padding:2.5rem; border-radius:20px; background:var(--card); border:1px solid var(--border); }
    .cv-top { display:flex; align-items:center; gap:1.5rem; }
    .cv-av { width:72px; height:72px; border-radius:18px; flex-shrink:0; background:linear-gradient(135deg,#3b82f6,#6366f1); display:flex; align-items:center; justify-content:center; font-size:1.5rem; font-weight:800; color:#fff; }
    .cv-name { font-size:1.25rem; font-weight:700; }
    .cv-role { font-size:.875rem; color:var(--blue-bright); font-weight:600; }
    .cv-loc { font-size:.8rem; color:var(--text2); }
    .cv-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; margin-top:2rem; }
    .cv-gl { font-size:.7rem; color:var(--text2); text-transform:uppercase; letter-spacing:.06em; }
    .cv-gv { font-size:.9375rem; font-weight:500; margin-top:.125rem; }
    .cv-actions { display:flex; gap:1rem; margin-top:2rem; flex-wrap:wrap; }
    .cv-note { font-size:.8rem; color:var(--text2); margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border); }

    /* Contact */
    .contact-g { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1.25rem; max-width:900px; margin:0 auto; }
    .cc { padding:1.5rem; border-radius:16px; text-decoration:none; background:var(--card); border:1px solid var(--border); transition:all .3s; display:block; }
    .cc:hover { border-color:rgba(59,130,246,.25); transform:translateY(-3px); }
    .cci { width:38px; height:38px; border-radius:10px; margin-bottom:1rem; background:rgba(59,130,246,.1); display:flex; align-items:center; justify-content:center; }
    .cci svg { width:18px; height:18px; color:var(--blue-bright); }
    .cc-label { font-size:.9375rem; font-weight:600; color:var(--text); }
    .cc-val { font-size:.8125rem; color:var(--text2); margin-top:.125rem; }

    /* Footer */
    .footer { border-top:1px solid var(--border); padding:2rem; text-align:center; font-size:.8125rem; color:var(--text2); position:relative; z-index:1; }

    /* Separator */
    .sep { border:0; border-top:1px solid var(--border); margin:0; }

    /* Responsive */
    @media(max-width:768px) {
      .nav-links, .nav-cta-desktop { display:none; }
      .mob-btn { display:block; }
      .hero { padding:6rem 1.5rem 3rem; }
      .stats { grid-template-columns:repeat(2,1fr); gap:1.25rem; }
      .cg { grid-template-columns:1fr; }
      .cv-top { flex-direction:column; text-align:center; }
      .cv-grid { grid-template-columns:1fr; }
      .cv-actions { justify-content:center; }
      .skills-grid { grid-template-columns:1fr; }
    }
  </style>
</head>
