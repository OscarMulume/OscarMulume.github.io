    .tl-item:last-child{border-left:0;padding-bottom:0}
    .tl-dot{position:absolute;left:-7px;top:0;width:12px;height:12px;border-radius:50%;background:var(--blue);border:3px solid var(--bg);box-shadow:0 0 0 3px rgba(59,130,246,.15)}
    .tl-dot.old{background:var(--text2);box-shadow:none}
    .tlh{display:flex;flex-wrap:wrap;align-items:center;gap:.75rem;margin-bottom:.25rem}
    .tlt{font-size:1.125rem;font-weight:700}
    .tlb{padding:.25rem .75rem;border-radius:100px;font-size:.7rem;font-weight:600}
    .tlb.now{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.2)}
    .tlb.past{background:rgba(255,255,255,.04);color:var(--text2)}
    .tlc{font-size:.875rem;color:var(--blue-br);font-weight:500;margin-bottom:.5rem}
    .tldesc{font-size:.9375rem;color:var(--text2);line-height:1.8;padding-left:1.25rem}
    .tldesc li::before{content:'▸';position:absolute;left:0;color:var(--blue);font-size:.8rem}
    .tldesc li{margin-bottom:.35rem;padding-left:1rem;position:relative}
    @media(max-width:900px){.contact-layout{grid-template-columns:1fr}}
    @media(max-width:768px){
      .nav-links,.nav-cta-desktop{display:none}
      .mob-btn{display:block}
      .hero{padding:6rem 1.5rem 3rem}
      .stats{grid-template-columns:repeat(2,1fr);gap:1.25rem}
      .cg{grid-template-columns:1fr}
      .process{grid-template-columns:repeat(2,1fr)}
      .footer-inner{grid-template-columns:1fr 1fr;gap:2rem}
      .footer-bottom{flex-direction:column;gap:1rem;text-align:center}
      .btns{flex-direction:column}.btns a{justify-content:center}
    }
    @media(max-width:480px){.process{grid-template-columns:1fr}.footer-inner{grid-template-columns:1fr}}
  </style>
</head>
