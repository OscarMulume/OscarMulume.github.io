    .sw{max-width:1200px;margin:0 auto;padding:6rem 2rem}
    .sh{text-align:center;margin-bottom:4rem}
    .sl{display:inline-block;font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--blue-br);margin-bottom:1rem}
