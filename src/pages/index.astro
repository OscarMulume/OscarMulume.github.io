    .step{text-align:center;padding:2rem 1.5rem}
    .step-num{width:48px;height:48px;border-radius:50%;background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.2);display:flex;align-items:center;justify-content:center;font-size:1.25rem;font-weight:800;color:var(--blue-br);margin:0 auto 1.25rem}
